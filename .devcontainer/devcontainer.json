{
  "name": "gcm-calculator",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:24",
  "forwardPorts": [3000],
  "appPort": ["3000:3000"],
  "postCreateCommand": "npm install",
  "mounts": [
    "source=gcm-calculator-claude-config,target=/home/node/.claude,type=volume"
  ],
  "remoteUser": "root",
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "biomejs.biome",
        "bradlc.vscode-tailwindcss",
        "vitest.explorer",
        "mikestead.dotenv"
      ],
      "terminals": [{}]
    }
  }
}
