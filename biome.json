{
    "$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
    "vcs": {
        "enabled": false,
        "clientKind": "git",
        "useIgnoreFile": false
    },
    "files": {
        "ignoreUnknown": false,
        "includes": [
            "**/src/**/*",
            "**/locale/**/*",
            "**/.vscode/**/*",
            "**/index.html",
            "**/vite.config.ts",
            "!**/src/routeTree.gen.ts",
            "!**/src/paraglide/**/*"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4
    },
    "assist": { "actions": { "source": { "organizeImports": "on" } } },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "style": {
                "noRestrictedImports": {
                    "level": "error",
                    "options": {
                        "patterns": [
                            {
                                "group": "^@mui/\\[^/\\]+$"
                            }
                        ]
                    }
                }
            },
            "nursery": {
                "useSortedClasses": "error"
            }
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "double"
        }
    },
    "css": {
        "parser": {
            "tailwindDirectives": true
        }
    }
}
